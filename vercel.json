{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://web-production-4012.up.railway.app/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://web-production-4012.up.railway.app/health"
    }
  ]
}